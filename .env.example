# Copy to ".env" in this folder (same level as package.json). Never commit .env.
# Do not paste real tokens into chat or screenshots.

# From @BotFather after /newbot (looks like 123456789:AAH...)
TELEGRAM_BOT_TOKEN=

# You choose this: a long random string (e.g. run: openssl rand -hex 32)
# Must match what you pass to setWebhook as secret_token.
TELEGRAM_WEBHOOK_SECRET=

# Public base URL only (no path). Example: https://abc123.ngrok-free.app
# Used by npm run register-webhook --workspace=backend
PUBLIC_WEBHOOK_URL=

# Google AI Studio → Get API key → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. If unset, tries gemini-2.5-flash-lite then gemini-2.5-flash (1.5/2.0 names are deprecated/removed).
# GEMINI_MODEL=gemini-2.5-flash-lite

PORT=3001
