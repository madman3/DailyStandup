# Copy to ".env" in this folder (same level as package.json). Never commit .env.
# Do not paste real tokens into chat or screenshots.

# From @BotFather after /newbot (looks like 123456789:AAH...)
TELEGRAM_BOT_TOKEN=

# You choose this: a long random string (e.g. run: openssl rand -hex 32)
# Must match what you pass to setWebhook as secret_token.
TELEGRAM_WEBHOOK_SECRET=

# Public base URL only (no path). Example: https://abc123.ngrok-free.app
# Used by npm run register-webhook --workspace=backend
PUBLIC_WEBHOOK_URL=

# Google AI Studio → Get API key → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Pin one model. If unset, the server tries gemini-2.5-flash then gemini-2.5-flash-lite (separate free-tier quotas).
# Free tier has low per-day limits; enable billing or reduce calls (see SKIP_STANDUP_CHAT_REPLY).
# GEMINI_MODEL=gemini-2.5-flash

# Skip the extra Gemini “coach reply” after each standup (saves 1 API call per message). Telegram still gets the bullet summary.
# SKIP_STANDUP_CHAT_REPLY=1

# Telegram: after each saved standup, reply with a short coach-style message (extra Gemini call).
# Set to "simple" to skip that and only send a plain bullet summary (no second model call).
# STANDUP_REPLY_MODE=simple

PORT=3001

# Production: attach a persistent volume to the path where backend/state.json lives, or data resets on every deploy.
# Replay: POST /api/replay with the same X-Telegram-Bot-Api-Secret-Token as ingest — uses last 50 stored standup texts.

# IANA timezone for which calendar day counts as "today" (e.g. America/Los_Angeles).
# Backend (Railway/local): USER_TIMEZONE
# Frontend build (Vercel/local): VITE_USER_TIMEZONE — use the same zone string.
USER_TIMEZONE=
# VITE_USER_TIMEZONE=
