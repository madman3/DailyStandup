# Copy to ".env" in this folder (same level as package.json). Never commit .env.
# Do not paste real tokens into chat or screenshots.

# From @BotFather after /newbot (looks like 123456789:AAH...)
TELEGRAM_BOT_TOKEN=

# You choose this: a long random string (e.g. run: openssl rand -hex 32)
# Must match what you pass to setWebhook as secret_token.
TELEGRAM_WEBHOOK_SECRET=

# Public base URL only (no path). Example: https://abc123.ngrok-free.app
# Used by npm run register-webhook --workspace=backend
PUBLIC_WEBHOOK_URL=

# Google AI Studio → Get API key → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Pin one model. If unset, the server tries gemini-2.5-flash then gemini-2.5-flash-lite (separate free-tier quotas).
# Free tier has low per-day limits; enable billing or reduce calls (see SKIP_STANDUP_CHAT_REPLY).
# GEMINI_MODEL=gemini-2.5-flash

# Emergency: skip all Gemini calls (same effect as Telegram /pause for parsing). Standups still save raw text.
# GEMINI_DISABLE=1

# After a quota-exhausted error, skip Gemini for this many ms (default 30 minutes). Cleared on /resume or successful parse.
# GEMINI_COOLDOWN_MS=1800000

# Telegram: /pause = save messages as text only (no Gemini). /resume = parse again. /aistatus = paused + cool-down state.

# Skip the extra Gemini “coach reply” after each standup (saves 1 API call per message). Telegram still gets the bullet summary.
# SKIP_STANDUP_CHAT_REPLY=1

# Telegram: after each saved standup, reply with a short coach-style message (extra Gemini call).
# Set to "simple" to skip that and only send a plain bullet summary (no second model call).
# STANDUP_REPLY_MODE=simple

PORT=3001

# --- Dashboard access control (cookie-based password gate) ---
# When set, the backend protects `/api/state`, `/api/telegram-status`, `/api/todos/*`, etc.
# The frontend shows a login form when it receives HTTP 401.
DASHBOARD_PASSWORD=

# Optional: secret used by express-session (defaults to TELEGRAM_WEBHOOK_SECRET or a dev value).
DASHBOARD_SESSION_SECRET=

# Optional: set to your Vercel frontend origin (e.g. https://daily-standup.vercel.app) for stricter CORS.
DASHBOARD_ORIGIN=

# --- Postgres (Supabase). When set anywhere the backend runs (local, Fly), SQLite is NOT used. ---
# Omit DATA_DIR on Fly if you only use Supabase. Prefer pooler URL + ssl from Supabase dashboard.
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
#
# One-off: copy local data/lifeos.db → Postgres (preview counts, then apply):
#   npm run migrate:sqlite-to-pg --workspace=backend
#   npm run migrate:sqlite-to-pg --workspace=backend -- --apply

# --- Google Sheets → job applications (hourly + POST /api/jobs/sync) ---
# Share the sheet with the service account email (client_email in the JSON).
# GOOGLE_SHEET_ID=1abc...spreadsheetId...
# A1 row = headers. Use columns named like: company, role, status, applied_date, last_updated, notes, id (optional).
# GOOGLE_SHEET_RANGE=Sheet1!A:Z
# Prefer a file path (Docker mount) over inline JSON:
# GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json
# Or one-line JSON (escape quotes) / base64:
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=
#
# Fly.io has no JSON file unless you bake it into the image — use B64, or set inline JSON as a Fly secret.
# After `fly secrets set` for sheet + service account, redeploy. Manual sync from your laptop:
#   npm run jobs:sync
# (VITE_API_URL first, then PUBLIC_WEBHOOK_URL + TELEGRAM_WEBHOOK_SECRET — both must match your Fly app, not an old Railway host.)
# Each jobs sync replaces the entire job_applications table from the sheet (sheet is source of truth).
#
# Job sort — cells without a 4-digit year (see lifeosDb parseSheetDateForSort):
#   row ≥ 3276 → 2026; 2800 ≤ row < 3276 → 2025; row < 2800 → 2024 (no heuristic).
# JOB_APPLIED_2026_FROM_ROW=3276
# JOB_APPLIED_2025_FROM_ROW=2800
# JOB_APPLIED_YEAR_2026=2026
# JOB_APPLIED_YEAR_2025=2025
# JOB_APPLIED_YEAR_2024=2024

# Optional: huge job sheets → tune Postgres upsert (defaults are usually enough after batching).
# PG_JOB_UPSERT_TIMEOUT_S=120
# PG_JOB_UPSERT_BATCH=75

# SQLite (default: <repo>/data/lifeos.db). First boot migrates backend/state.json into the DB if it is empty.
# Local dev: do not point DATA_DIR at /var/lib/... (macOS/Linux: permission denied unless you sudo).
# On Docker/local, set a mounted volume path your process can write to, e.g.:
# DATA_DIR=/var/lib/lifeos
# SQLITE_PATH=/var/lib/lifeos/lifeos.db

# Production: mount DATA_DIR (or set SQLITE_PATH) so the DB survives restarts. Do not commit *.db.
# Replay: POST /api/replay with the same X-Telegram-Bot-Api-Secret-Token as ingest — uses last 50 stored standup texts.

# IANA timezone for which calendar day counts as "today" (e.g. America/Los_Angeles).
# Backend (Fly/local): USER_TIMEZONE
# Frontend build (Vercel/local): VITE_USER_TIMEZONE — use the same zone string.
USER_TIMEZONE=
# VITE_USER_TIMEZONE=

# Dashboard (Vite): optional API base URL, no trailing slash. When unset locally, `/api` is proxied to PORT above.
# Vite reads this from the same repo-root `.env` (see frontend/vite.config.js envDir).
# VITE_API_URL=https://your-app.fly.dev

# Dashboard: protein chart reference line (grams per day). Default 150 if unset.
# VITE_PROTEIN_GOAL_GRAMS=150
